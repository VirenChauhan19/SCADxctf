# Copy this file to ".env" before running the app.

# Postgres connection string (Neon, Supabase, or Cloud SQL).
# Use the provider's POOLED connection string and keep sslmode=require.
# Neon example:
DATABASE_URL="postgresql://user:password@host-pooler.region.neon.tech/dbname?sslmode=require"

# Secret used to sign session cookies (JWT).
# REQUIRED in production: must be a long, random string (>= 32 chars) and NOT the
# placeholder below. The app refuses to start in production with a weak secret.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# Optional: gate self-registration for a truly private team. When set, new
# sign-ups (after the first/bootstrap account) must supply this exact invite code.
# Leave unset to allow open athlete sign-up (fine for local/demo use).
# TEAM_INVITE_CODE=""
